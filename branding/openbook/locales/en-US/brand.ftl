# OpenBook branding strings (Fluent form).
# Mirrors browser/branding/<channel>/locales/en-US/brand.ftl. These are the
# brand-* terms the rest of the Firefox front-end references with { -brand-* }.
# Keeping the exact term keys Firefox expects means no upstream .ftl needs to be
# patched for strings to resolve. No Firefox/Mozilla trademark here (§13).

-brand-shorter-name = OpenBook
-brand-short-name = OpenBook
-brand-full-name = OpenBook
# Product name without the company; OpenBook uses the same name for all forms.
-brand-product-name = OpenBook
-vendor-short-name = OpenBook

# Trademark / legal line shown in About. OpenBook is not affiliated with Mozilla;
# the line deliberately avoids any Firefox or Mozilla mark.
trademarkInfo = OpenBook is an independent, privacy-hardened browser built from
    Firefox source code under the Mozilla Public License. It is not produced by
    or endorsed by Mozilla. Firefox is a trademark of the Mozilla Foundation.
